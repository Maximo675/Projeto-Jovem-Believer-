{
    "include": ["."],
    "exclude": [
        "venv",
        ".venv",
        "**/node_modules",
        "**/__pycache__",
        "**/*.egg-info",
        "**/*.pyc",
        "**/*.pyo",
        "**/*.pyd",
        ".git",
        ".github",
        ".pytest_cache",
        ".mypy_cache",
        "dist",
        "build",
        ".env",
        ".DS_Store",
        "*.egg-info",
        ".VS_Code"
    ],
    "pythonVersion": "3.14",
    "pythonPlatform": "Windows",
    "typeCheckingMode": "off",
    "extraPaths": ["backend"],
    "reportMissingImports": false,
    "reportMissingTypeStubs": false
}
