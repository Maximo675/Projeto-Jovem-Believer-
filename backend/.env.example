# =====================================
# CONFIGURAÇÕES GERAIS
# =====================================
FLASK_ENV=development
FLASK_APP=app
DEBUG=True

# =====================================
# BANCO DE DADOS
# =====================================
# SQLite (desenvolvimento)
DATABASE_URL=sqlite:///instance/app.db

# PostgreSQL (produção) - descomente para usar
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/infant_id

# =====================================
# SEGURANÇA
# =====================================
SECRET_KEY=sua-chave-secreta-super-long-e-complexa-aqui
JWT_SECRET_KEY=sua-chave-jwt-super-secreta-aqui
JWT_EXPIRATION_HOURS=24

# =====================================
# IA - OpenAI
# =====================================
OPENAI_API_KEY=sua-chave-openai-aqui
OPENAI_MODEL=gpt-3.5-turbo

# =====================================
# IA - Alternativa (HuggingFace)
# =====================================
# HUGGINGFACE_API_KEY=sua-chave-huggingface-aqui
# HUGGINGFACE_MODEL=modelo-desejado

# =====================================
# CORS
# =====================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1

# =====================================
# EMAIL (Opcional)
# =====================================
MAIL_SERVER=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@infantid.com

# =====================================
# LOGGING
# =====================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =====================================
# API EXTERNA (Opcional)
# =====================================
# Configurações de APIs externas que você possa usar

# =====================================
# AMBIENTE
# =====================================
COMPANY=Group Akiyama
PROJECT_NAME=INFANT.ID - Plataforma de Ensino
